# Required – get free keys from these services
REPLICATE_API_TOKEN=r8_xxxxx                # from replicate.com – $0.10 free credit
SYNC_LABS_API_KEY=sl_xxxxx                  # from sync.so – 3 free videos/month
BACKBLAZE_KEY_ID=xxxxx                      # free 10GB storage from Backblaze B2
BACKBLAZE_APP_KEY=xxxxx
BACKBLAZE_BUCKET_NAME=ai-music-videos

# Optional (use local models instead of cloud)
USE_LOCAL_AVATAR=true                       # use OmniAvatar on your GPU
LOCAL_MODELS_PATH=/app/models

# Server configuration
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:///./test.db

# For music URL extraction (e.g., from Suno)
YOUTUBE_DL_PATH=/usr/local/bin/yt-dlp
